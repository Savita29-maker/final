# Environment Configuration Example
# Copy this file to .env and update with your values

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/smart_patient_queue
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=smart_patient_queue
DATABASE_USER=postgres
DATABASE_PASSWORD=password

# API
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000/api

# Frontend
STREAMLIT_PORT=8501

# Twilio SMS Configuration (Optional - for real SMS notifications)
# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ML Model
ML_MODEL_PATH=backend/app/services/wait_time_model.pkl
SCALER_PATH=backend/app/services/scaler.pkl

# Notifications (for future production use)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890

SENDGRID_API_KEY=your_sendgrid_api_key
SENDER_EMAIL=noreply@hospital.com

# Debug
DEBUG=False
LOG_LEVEL=info
